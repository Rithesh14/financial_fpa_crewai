# Financial FP&A System - Environment Configuration

# ── Groq (Recommended) ────────────────────────────────────────────────────────
# Get your key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_BASE=https://api.groq.com/openai/v1
OPENAI_MODEL_NAME=llama-3.1-8b-instant
OPENAI_API_KEY=your_groq_api_key_here   # duplicate needed for CrewAI compatibility

# ── Ollama (Local / Offline Alternative) ─────────────────────────────────────
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL_NAME=llama3.1
# OPENAI_API_KEY=NA

# ── Optional: Serper API Key for Internet Search (Market Research) ────────────
# Get your key from: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here
