# Financial FP&A System - Environment Configuration
# For Ollama (Local LLM)

# Ollama Configuration
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_MODEL_NAME=llama3.1
OPENAI_API_KEY=NA

# Optional: Serper API Key for Internet Search (Market Research)
# Get your key from: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# Note: Since you're using Ollama locally, you don't need an actual OpenAI API key.
# The OPENAI_API_KEY is set to "NA" as a placeholder.
# CrewAI will use your local Ollama instance at http://localhost:11434
